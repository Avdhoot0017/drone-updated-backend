{
  "name": "drone-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend API for Drone Surveillance Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:seed:master": "tsx src/prisma/seed-master.ts",
    "db:seed:admin": "tsx src/prisma/seed-admin.ts",
    "db:seed:dev": "tsx src/prisma/seed-dev.ts",
    "db:seed:prod": "node dist/prisma/seed.js",
    "db:seed:master:prod": "node dist/prisma/seed-master.js",
    "db:seed:admin:prod": "node dist/prisma/seed-admin.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && npm run db:seed:master && npm run db:seed:admin",
    "sync:manual": "tsx src/jobs/runSync.ts",
    "sync:fresh": "tsx src/jobs/freshSync.ts",
    "sync:fresh:prod": "node dist/jobs/freshSync.js",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@getbrevo/brevo": "^5.0.4",
    "@prisma/client": "^5.22.0",
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@types/puppeteer": "^5.4.7",
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "docx-merger": "^1.2.2",
    "docxtemplater": "^3.68.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.14",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
