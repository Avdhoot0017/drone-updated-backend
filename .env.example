# =============================================================================
# DRONE DASHBOARD - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# TIMEZONE & SYNC SCHEDULE
# -----------------------------------------------------------------------------
# Timezone for the application (Indian Standard Time)
TZ=Asia/Kolkata

# Sync schedule in cron format (default: 8 PM daily)
# Format: minute hour day month weekday
SYNC_CRON_SCHEDULE=0 20 * * *

# Enable/disable automatic sync
SYNC_ENABLED=true

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/drone_dashboard?schema=public

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# GOOGLE SHEETS API
# -----------------------------------------------------------------------------
# Path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=./config/service-account.json

# Google Sheet ID (from the sheet URL)
# Example URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Sheet names (comma-separated, matching tabs in the spreadsheet)
GOOGLE_SHEET_TABS=Raigad,Ratnagiri,Sindhudurg,Palghar,Thane

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# -----------------------------------------------------------------------------
# AWS S3 CONFIGURATION
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name

# -----------------------------------------------------------------------------
# NOTIFICATION SERVICES
# -----------------------------------------------------------------------------
# Email (Brevo/SendinBlue)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Your Organization Name

# Case Notification Recipients
COMMISSIONER_EMAIL=commissioner@example.com
JOINT_COMMISSIONER_EMAIL=jointcommissioner@example.com

# -----------------------------------------------------------------------------
# EXOTEL SMS, WHATSAPP & VOICE
# -----------------------------------------------------------------------------
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-api-token
EXOTEL_ACCOUNT_SID=your-exotel-account-sid
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_SENDER_ID=your-exophone-number

# DLT Registration (Required for production SMS in India)
EXOTEL_DLT_ENTITY_ID=
EXOTEL_DLT_TEMPLATE_ID=

# WhatsApp Configuration
EXOTEL_WHATSAPP_NUMBER=
EXOTEL_WHATSAPP_TEMPLATE_NAME=case_notification

# Voice Call Configuration
EXOTEL_GREETING_APP_ID=your-greeting-app-id
EXOTEL_GREETING_AUDIO_URL=https://your-bucket.s3.region.amazonaws.com/audio/greeting.mp3
